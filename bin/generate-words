#!/usr/bin/env php
<?php

// Check if the file is being run from the project root or from the bin directory
if (file_exists(__DIR__ . '/../vendor/autoload.php')) {
    require __DIR__ . '/../vendor/autoload.php';
} elseif (file_exists(__DIR__ . '/../../vendor/autoload.php')) {
    require __DIR__ . '/../../vendor/autoload.php';
} else {
    die("Autoloader not found. Please run 'composer install' first.\n");
}

use Tlab\PortugueseWordGenerator\PortugueseWordGenerator;

// Parse command line arguments
$numWords = 10;    // Default number of words
$wordLength = 6;   // Default word length
$outputFile = null; // Default to stdout
$easyMode = false;  // Default to standard complexity
$language = 'portuguese'; // Default language

// Process command line arguments if provided
if (isset($argv[1]) && is_numeric($argv[1]) && $argv[1] > 0) {
    $numWords = (int)$argv[1];
}

if (isset($argv[2]) && is_numeric($argv[2]) && $argv[2] > 0) {
    $wordLength = (int)$argv[2];
}

if (isset($argv[3]) && $argv[3] !== 'null') {
    $outputFile = $argv[3];
}

if (isset($argv[4])) {
    if (strtolower($argv[4]) === 'easy') {
        $easyMode = true;
    } else {
        $language = strtolower($argv[4]);
    }
}

// Check for a fifth parameter that could be the language when easy mode is specified
if (isset($argv[5])) {
    $language = strtolower($argv[5]);
}

// Create the generator with the appropriate language and mode
$generator = new WordGeneratorFacade($language, $easyMode);

// Generate the requested number of words
$generatedWords = $generator->generateWords($numWords, $wordLength);

// Output the generated words
$output = implode(PHP_EOL, $generatedWords) . PHP_EOL;

// Write to file or stdout
if ($outputFile) {
    try {
        if ($generator->saveToFile($generatedWords, $outputFile)) {
            echo "Successfully wrote $numWords words to $outputFile" . PHP_EOL;
        } else {
            echo "Error writing to file." . PHP_EOL;
        }
    } catch (Exception $e) {
        echo "Error writing to file: {$e->getMessage()}" . PHP_EOL;
    }
} else {
    echo $output;
}
